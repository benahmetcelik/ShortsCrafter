# Hugging Face API Token
# Token al: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
OPENROUTER_API_KEY=your_openrouter_key_here
MAX_GAP=0.1
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
VIDEO_FPS=30
SCENE_COUNT=4
MIN_SILENCE_SEC=0.12    # Bu sürenin üstündeki boşluklar kırpılır
KEEP_SILENCE_SEC=0.03   # Kelimeler arası bırakılan minimum nefes payı
SILENCE_THRESHOLD=0.012 # Sessizlik algılama hassasiyeti


# Video ayarlari (opsiyonel)
# VIDEO_WIDTH=1080
# VIDEO_HEIGHT=1920
# VIDEO_FPS=30
# VIDEO_BITRATE=3000k
# AUDIO_BITRATE=192k
# TTS_VOICE=tr-TR-AhmetNeural
# FLUX_MODEL=black-forest-labs/FLUX.1-schnell
# OPENROUTER_MODEL=gpt-3.5-turbo
